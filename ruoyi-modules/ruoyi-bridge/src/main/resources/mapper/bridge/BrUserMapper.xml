<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.bridge.mapper.BrUserMapper">

    <resultMap type="BrUser" id="BrUserResult">
        <result property="userId"         column="user_id"          />
        <result property="identityId"     column="identity_id"      />
        <result property="channelKey"     column="channel_key"      />
        <result property="channelUserId"  column="channel_user_id"  />
        <result property="serverId"       column="server_id"        />
        <result property="playerId"       column="player_id"        />
        <result property="createTime"     column="create_time"      />
        <result property="lastLoginTime"  column="last_login_time"  />
    </resultMap>

    <sql id="selectVo">
        select user_id, identity_id, channel_key, channel_user_id,
               server_id, player_id, create_time, last_login_time
        from br_user
    </sql>

    <select id="selectByUserId" parameterType="Long" resultMap="BrUserResult">
        <include refid="selectVo"/>
        where user_id = #{userId}
    </select>

    <select id="selectByIdentityId" parameterType="String" resultMap="BrUserResult">
        <include refid="selectVo"/>
        where identity_id = #{identityId}
    </select>

    <select id="selectByUserKey" resultMap="BrUserResult">
        <include refid="selectVo"/>
        where channel_key = #{channelKey}
          and channel_user_id = #{channelUserId}
          and server_id = #{serverId}
    </select>

    <select id="selectList" parameterType="BrUser" resultMap="BrUserResult">
        <include refid="selectVo"/>
        <where>
            <if test="channelKey != null and channelKey != ''">
                AND channel_key = #{channelKey}
            </if>
            <if test="channelUserId != null and channelUserId != ''">
                AND channel_user_id = #{channelUserId}
            </if>
            <if test="serverId != null">
                AND server_id = #{serverId}
            </if>
        </where>
        order by user_id asc
    </select>

    <insert id="insert" parameterType="BrUser" useGeneratedKeys="true" keyProperty="userId">
        insert into br_user (
            identity_id, channel_key, channel_user_id,
            server_id, player_id, last_login_time
        ) values (
            #{identityId}, #{channelKey}, #{channelUserId},
            #{serverId}, #{playerId}, #{lastLoginTime}
        )
    </insert>

    <update id="update" parameterType="BrUser">
        update br_user
        <set>
            <if test="playerId != null">player_id = #{playerId},</if>
            <if test="lastLoginTime != null">last_login_time = #{lastLoginTime},</if>
            <if test="serverId != null">server_id = #{serverId},</if>
        </set>
        where user_id = #{userId}
    </update>

    <delete id="deleteByIds" parameterType="Long">
        delete from br_user where user_id in
        <foreach item="userId" collection="array" open="(" separator="," close=")">
            #{userId}
        </foreach>
    </delete>

</mapper>
