<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.GameFieldDefineMapper">

    <resultMap type="GameFieldDefine" id="GameFieldDefineResult">
        <result property="fieldId"       column="field_id"       />
        <result property="entityType"    column="entity_type"    />
        <result property="fieldLabel"    column="field_label"    />
        <result property="fieldCode"     column="field_code"     />
        <result property="fieldType"     column="field_type"     />
        <result property="fieldOptions"  column="field_options"  />
        <result property="isExport"      column="is_export"      />
        <result property="isRequired"    column="is_required"    />
        <result property="defaultValue"  column="default_value"  />
        <result property="sort"          column="sort"           />
        <result property="status"        column="status"         />
        <result property="createBy"      column="create_by"      />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"      column="update_by"      />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"        column="remark"         />
    </resultMap>

    <sql id="selectGameFieldDefineVo">
        select field_id, entity_type, field_label, field_code, field_type,
               field_options, is_export, is_required, default_value, sort, status,
               create_by, create_time, update_by, update_time, remark
        from game_field_define
    </sql>

    <select id="selectGameFieldDefineList" parameterType="GameFieldDefine" resultMap="GameFieldDefineResult">
        <include refid="selectGameFieldDefineVo"/>
        <where>
            <if test="entityType != null and entityType != ''">
                AND entity_type = #{entityType}
            </if>
            <if test="fieldLabel != null and fieldLabel != ''">
                AND field_label like concat('%', #{fieldLabel}, '%')
            </if>
            <if test="fieldCode != null and fieldCode != ''">
                AND field_code like concat('%', #{fieldCode}, '%')
            </if>
            <if test="fieldType != null and fieldType != ''">
                AND field_type = #{fieldType}
            </if>
            <if test="isExport != null and isExport != ''">
                AND is_export = #{isExport}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="params.beginTime != null and params.beginTime != ''">
                AND create_time &gt;= #{params.beginTime}
            </if>
            <if test="params.endTime != null and params.endTime != ''">
                AND create_time &lt;= #{params.endTime}
            </if>
        </where>
        order by sort asc
    </select>

    <select id="selectGameFieldDefineById" parameterType="Long" resultMap="GameFieldDefineResult">
        <include refid="selectGameFieldDefineVo"/>
        where field_id = #{fieldId}
    </select>

    <select id="selectGameFieldDefineByEntity" parameterType="String" resultMap="GameFieldDefineResult">
        <include refid="selectGameFieldDefineVo"/>
        where entity_type = #{entityType}
        order by sort asc
    </select>

    <insert id="insertGameFieldDefine" parameterType="GameFieldDefine">
        insert into game_field_define (
            <if test="entityType != null and entityType != ''">entity_type,</if>
            <if test="fieldLabel != null and fieldLabel != ''">field_label,</if>
            <if test="fieldCode != null and fieldCode != ''">field_code,</if>
            <if test="fieldType != null and fieldType != ''">field_type,</if>
            <if test="fieldOptions != null and fieldOptions != ''">field_options,</if>
            <if test="isExport != null and isExport != ''">is_export,</if>
            <if test="isRequired != null and isRequired != ''">is_required,</if>
            <if test="defaultValue != null and defaultValue != ''">default_value,</if>
            <if test="sort != null">sort,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        )values(
            <if test="entityType != null and entityType != ''">#{entityType},</if>
            <if test="fieldLabel != null and fieldLabel != ''">#{fieldLabel},</if>
            <if test="fieldCode != null and fieldCode != ''">#{fieldCode},</if>
            <if test="fieldType != null and fieldType != ''">#{fieldType},</if>
            <if test="fieldOptions != null and fieldOptions != ''">#{fieldOptions},</if>
            <if test="isExport != null and isExport != ''">#{isExport},</if>
            <if test="isRequired != null and isRequired != ''">#{isRequired},</if>
            <if test="defaultValue != null and defaultValue != ''">#{defaultValue},</if>
            <if test="sort != null">#{sort},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        )
    </insert>

    <update id="updateGameFieldDefine" parameterType="GameFieldDefine">
        update game_field_define
        <set>
            <if test="entityType != null and entityType != ''">entity_type = #{entityType},</if>
            <if test="fieldLabel != null and fieldLabel != ''">field_label = #{fieldLabel},</if>
            <if test="fieldCode != null and fieldCode != ''">field_code = #{fieldCode},</if>
            <if test="fieldType != null and fieldType != ''">field_type = #{fieldType},</if>
            <if test="fieldOptions != null">field_options = #{fieldOptions},</if>
            <if test="isExport != null and isExport != ''">is_export = #{isExport},</if>
            <if test="isRequired != null and isRequired != ''">is_required = #{isRequired},</if>
            <if test="defaultValue != null">default_value = #{defaultValue},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where field_id = #{fieldId}
    </update>

    <delete id="deleteGameFieldDefineById" parameterType="Long">
        delete from game_field_define where field_id = #{fieldId}
    </delete>

    <delete id="deleteGameFieldDefineByIds" parameterType="Long">
        delete from game_field_define where field_id in
        <foreach item="fieldId" collection="array" open="(" separator="," close=")">
            #{fieldId}
        </foreach>
    </delete>

</mapper>
