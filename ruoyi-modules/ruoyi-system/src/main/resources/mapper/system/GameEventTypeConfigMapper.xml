<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.GameEventTypeConfigMapper">

    <resultMap type="GameEventTypeConfig" id="EventTypeResult">
        <result property="id"          column="id" />
        <result property="eventType"   column="event_type" />
        <result property="eventName"   column="event_name" />
        <result property="status"      column="status" />
        <result property="paramDefine" column="param_define" />
        <result property="remark"      column="remark" />
        <result property="createBy"    column="create_by" />
        <result property="createTime"  column="create_time" />
        <result property="updateBy"    column="update_by" />
        <result property="updateTime"  column="update_time" />
    </resultMap>

    <sql id="selectVo">
        select id, event_type, event_name, status, param_define,
               remark, create_by, create_time, update_by, update_time
        from game_event_type_config
    </sql>

    <select id="selectList" parameterType="GameEventTypeConfig" resultMap="EventTypeResult">
        <include refid="selectVo"/>
        <where>
            <if test="eventType != null and eventType != ''">
                AND event_type like concat('%', #{eventType}, '%')
            </if>
            <if test="eventName != null and eventName != ''">
                AND event_name like concat('%', #{eventName}, '%')
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by id asc
    </select>

    <select id="selectById" parameterType="Long" resultMap="EventTypeResult">
        <include refid="selectVo"/>
        where id = #{id}
    </select>

    <select id="selectByEventType" parameterType="String" resultMap="EventTypeResult">
        <include refid="selectVo"/>
        where event_type = #{eventType}
    </select>

    <insert id="insert" parameterType="GameEventTypeConfig">
        insert into game_event_type_config (
            <if test="eventType != null and eventType != ''">event_type,</if>
            <if test="eventName != null and eventName != ''">event_name,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="paramDefine != null and paramDefine != ''">param_define,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        )values(
            <if test="eventType != null and eventType != ''">#{eventType},</if>
            <if test="eventName != null and eventName != ''">#{eventName},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="paramDefine != null and paramDefine != ''">#{paramDefine},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        )
    </insert>

    <update id="update" parameterType="GameEventTypeConfig">
        update game_event_type_config
        <set>
            <if test="eventType != null and eventType != ''">event_type = #{eventType},</if>
            <if test="eventName != null and eventName != ''">event_name = #{eventName},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="paramDefine != null">param_define = #{paramDefine},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById" parameterType="Long">
        delete from game_event_type_config where id = #{id}
    </delete>

    <delete id="deleteByIds" parameterType="Long">
        delete from game_event_type_config where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
